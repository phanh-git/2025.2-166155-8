<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<!-- 
    calculator.fxml
    Open this file in Scene Builder to visually edit the layout.
    fx:controller links this view to CalculatorController.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CalculatorController"
      prefWidth="300" prefHeight="420"
      spacing="10"
      style="-fx-background-color: #f0f0f0; -fx-padding: 15;">

    <!-- ── Display ── -->
    <TextField fx:id="displayField"
               editable="false"
               alignment="CENTER_RIGHT"
               prefHeight="60"
               style="-fx-font-size: 26px; -fx-font-weight: bold;
                      -fx-background-color: white;
                      -fx-border-color: #cccccc; -fx-border-radius: 4;
                      -fx-background-radius: 4;" />

    <!-- ── Button Grid ── -->
    <GridPane hgap="6" vgap="6">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints prefHeight="60" />
            <RowConstraints prefHeight="60" />
            <RowConstraints prefHeight="60" />
            <RowConstraints prefHeight="60" />
            <RowConstraints prefHeight="60" />
        </rowConstraints>

        <!-- Row 0: C  (empty)  (empty)  / -->
        <Button fx:id="btnClear"  text="C"  onAction="#handleClear"
                maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button fx:id="btnDiv"    text="/"  onAction="#handleDiv"
                maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <!-- Row 1: 7  8  9  * -->
        <Button fx:id="btn7" text="7" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button fx:id="btn8" text="8" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button fx:id="btn9" text="9" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Button fx:id="btnMul" text="*" onAction="#handleMul" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <!-- Row 2: 4  5  6  - -->
        <Button fx:id="btn4" text="4" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button fx:id="btn5" text="5" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button fx:id="btn6" text="6" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <Button fx:id="btnSub" text="-" onAction="#handleSub" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <!-- Row 3: 1  2  3  + -->
        <Button fx:id="btn1" text="1" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Button fx:id="btn2" text="2" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Button fx:id="btn3" text="3" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <Button fx:id="btnAdd" text="+" onAction="#handleAdd" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="3" GridPane.rowIndex="3"/>

        <!-- Row 4: 0  .  (empty)  = -->
        <Button fx:id="btn0" text="0" onAction="#handleNumber" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Button fx:id="btnDot" text="." onAction="#handleDot" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: white; -fx-font-size:18px; -fx-background-radius:4;"
                GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Button fx:id="btnEquals" text="=" onAction="#handleEquals" maxWidth="Infinity" maxHeight="Infinity"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size:18px; -fx-font-weight:bold; -fx-background-radius:4;"
                GridPane.columnIndex="3" GridPane.rowIndex="4"/>
    </GridPane>
</VBox>
