@startuml
title Sequence Diagram 2 - Design Level
autonumber

actor "Bộ phận đặt hàng quốc tế" as A
boundary "OverseasDashboard" as B
control "OverseasOrderController" as C
control "OverseasOrderService" as S
entity "SaleRequestRepository" as SRR
entity "SiteOrderRepository" as SOR
entity "SaleRequest" as Req
entity "SiteOrder" as Order

alt Không có site nào đáp ứng hoặc không đủ để gợi ý
  A -> B : buildRequestDetailPage(request)
  A -> B : click "Tìm kiếm hàng trong các site"
  B -> B : suggestionEngine.buildItemPlan(item)
  B -> B : buildEmptyState("Không có site nào đáp ứng được...")
  B --> A : showError("Gợi ý chưa hoàn chỉnh", errors)
else Báo hủy đến bên sale
  A -> B : buildRequestDetailPage(request)
  A -> B : click "Báo hủy đến bên sale"
  B -> B : handleCancelRequest(request)
  B -> C : cancelSaleRequestByOverseas(requestId, reason)
  C -> S : cancelSaleRequestByOverseas(requestId, reason)
  S -> SRR : findById(saleRequestId)
  SRR --> S : SaleRequest
  S -> SOR : findBySaleRequestId(saleRequestId)
  SOR --> S : List<SiteOrder>
  alt chưa có đơn site nào
    S -> SRR : updateStatusAndCancellation(saleRequestId,\nCANCELLED, false, request.getCancelRequestReason(), reason)
  else đã có đơn site
    loop từng SiteOrder order
      S -> SOR : updateStatusWithReason(order.getId(), CANCELLED, reason)
    end
    S -> SRR : updateStatusAndCancellation(saleRequestId,\nCANCELLED, false, request.getCancelRequestReason(), reason)
  end
  S --> C : void
  C --> B : void
  B -> B : refreshRequestDetailPage(reloadSaleRequest(request.getId()), false)
  B --> A : showInfo("Đã hủy yêu cầu")
end

@enduml
